// Mera.jl multi-code capability matrix — source for docs/src/assets/MulticodeCapabilities.png
// Render: dot -Tpng -Gdpi=170 docs/multicode_capabilities.dot -o docs/src/assets/MulticodeCapabilities.png
//
// Companion to TypeHierarchy.png: that one maps codes -> structs; this one compares what each
// code supports. Header colour = family (orange native, blue grid/AMR, green particle/moving-mesh).
// Grounded in the "Supported codes" table in docs/src/multicode.md + the AREPO gas/projection rows.
digraph Capabilities {
    bgcolor="transparent";
    pad=0.2;
    node [shape=plaintext, fontname="Helvetica"];

    M [label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="7">
